		// Rope: Rope
		// Planter: Planter
		// Rail: Rail
		// Seeds: Seeds
		// Air: Air (Remove)
		// Wall: Wall
		// Options: Replacement Options
		// SameType: Same Type
	}

	Wiring: {
		// Title: Wand of Wiring
		// WireTypes: Wire Types
		// RedWire: Red Wire
		// GreenWire: Green Wire
		// BlueWire: Blue Wire
		// YellowWire: Yellow Wire
		// Actuator: Actuator
		// Mode: Mode
		// Place: Place
		// Remove: Remove
	}

	Safekeeping: {
		// Title: Wand of Safekeeping
		// Mode: Mode
		// Protect: Protect
		// Unprotect: Unprotect
		// ProtectTiles: Protect Tiles
		// ProtectWalls: Protect Walls
		// ClearAll: Clear All
		// ClearConfirm: Click to Confirm!
	}

	Coating: {
		// Title: Wand of Coating
		// Mode: Mode
		// PaintTile: Paint Tile
		// PaintWall: Paint Wall
		// ScrapePaint: Scrape Paint
		// ScrapeMoss: Scrape Moss
		// HarvestMoss: Harvest Moss
		// PaintColor: Paint Color
		// CoatingType: Coating
		// Illuminant: Illuminant
		// Echo: Echo
		// Ignore: Ignore
		// On: On
		// Off: Off
		// Repaint: Repaint
		// EyedropperHint: Alt+click a painted tile to copy its colour into Paint Color.

		# Color Replace action (S8 2026-04-28; ColorReplacePlan.md §3).
		# One-shot action: left-click fires the replace using the stored
		# (source colour, target colour) on the current channel (Tile/Wall
		# follows the wand's Mode toggle); right-click opens the picker SubUI.
		# Either side = Ignore (255) silently no-ops the action.
		ColorReplace: {
			// Section: Color Replace
			// SubUITitle: Color Replace
			// SourceLabel: Source colour (only this is matched)
			// TargetLabel: Target colour (matched becomes this)
			# S9 2026-04-28: Channel toggle reinstated per ColorReplacePlan §3.4 —
			# decouples Color Replace from the wand's CoatingMode toggle row.
			// ChannelTile: Tile
			// ChannelWall: Wall
			# S10 2026-04-28: operation result toasts (Phase 2 ship).
			// NoSelection: Color Replace: no selection.
			// NoChanges: Color Replace: no matching paint in selection.
			// Changed: Replaced paint on {0} tile(s).
			/* ButtonTooltipFmt:
				'''
				Color Replace
				Source: {0}
				Target: {1}
				Channel: {2}
				Left-click to select this mode. Right-click to configure.
				Cast the wand at a selection to fire.
				''' */
		}
	}

	CollapsibleSection: {
		// ExpandTooltip: Expand section
		// CollapseTooltip: Collapse section
		// PopoutTooltip: Pop out into a draggable mini-panel
	}

	Fluids: {
		// Title: Wand of Fluids
		// PlaceType: Liquid Type
		// Water: Water
		// Lava: Lava
		// Honey: Honey
		// Shimmer: Shimmer
		// Bubble: Bubble Block
		// FillMode: Fill Mode
		// FullLiquid: Full Liquid
		// RainFill: Rain Fill
		// PocketFill: Pocket Fill
		// Operation: Operation
		// Fill: Fill
		// Drain: Drain
		FluidOptions: Opzioni Fluidi
		CoatInBubble: Rivestimento a Bolla
		MixLiquids: Miscela Liquidi
		/* OverwriteLiquids:
			'''
			Overwrite Liquids
			When enabled, pouring a liquid replaces existing different-typed liquid
			(e.g. water replaces lava). When disabled, existing liquid blocks the pour.
			Has no effect when Mix Liquids is on.
