// Conditions.NonCraftable: Not craftable. Cycle with right click in inventory.

// ── Chat Messages ─────────────────────────────────────────
// Localization keys for all in-game chat feedback messages.
// These replace hardcoded Main.NewText() strings across the codebase.
Messages: {
	// ── Common ──────────────────────────────────────────────
	// SelectionCancelled: Selection cancelled.
	// S8 2026-04-22 — keybind hint when InventoryView toggle pressed without a participating wand held.
	// S9 vocabulary pass: drop "Inventory View" user-facing wording (DesignDoc Phase A).
	// InventoryViewNoParticipant: The block picker is only available for the Wand of Building, Wand of Replacement, and Wand of Torches.
	// SwitchedToMode: Switched to {0} mode
	// ThicknessChanged: Thickness: {0} — {1}
	// StampUnlocked: Stamp unlocked. Click to set new anchor.
	// SelectionUnlocked: Selection unlocked. Move to adjust end point.
	// SelectionCleared: Selection cleared.
	// ── Tooltip strings ─────────────────────────────────────
	// ModeInstant: Click and drag to select area
	// ModeSelect: Click start, then click end
	// ModeConfirm: Click start, click end, click to confirm
	// ModeStamp: Click start, click end, click to lock stamp, click to repeat
	// CycleHint: Right-click in inventory to cycle modes
	// PickaxeHint: Uses your strongest pickaxe for tile power checks
	// ObtainHint: "[c/AAAAAA:Obtain other modes by right-clicking this wand in your inventory]"
	// ── Building ────────────────────────────────────────────
	// NoSuitableItem: No suitable item found for {0}.
	// NeedHave: Need {0} {1}, have {2}. Operation cancelled.
	// NoTilesPlaced: No tiles could be placed.
	// NoWallItemFound: No wall item found in inventory.
	// NoWallsPlaced: No walls could be placed.
	// 2026-04-23 Session 1 (Letter #10 §6) — Interrupt mode refuses to run when the
	// chosen item isn't currently in inventory. Shown in red chat instead of silently
	// substituting. Applies to both tile pins and wall pins.
	// ChosenMissingUnderInterrupt: chosen item is not in inventory — Interrupt mode will not substitute. Operation cancelled.
	// ── Dismantling ─────────────────────────────────────────
	// NoTilesDestroyed: No tiles were destroyed.
	// ── Void Everything ─────────────────────────────────────
	// VoidRequiresCarefree: Void Everything requires Carefree Mode to be enabled.
	// VoidSinglePlayerOnly: Void Everything is currently only available in single-player.
	// NoSelectionActive: No selection is active. Use a wand to select an area first.
	// NothingToVoid: Nothing to void in the selected area.
	// ── Replacement ─────────────────────────────────────────
	// NoSourceItems: No {0} items in inventory to identify source tile.
	// SameSourceTarget: Source and target are the same tile [i:{0}].
	// NoTargetItems: No {0} items found in inventory.
	// NoSourceInSelection: No {0} found in selection.
	// NeedTargetItems: Need {0} [i:{1}], have {2}.
	// NoTilesReplaced: No tiles could be replaced.
	// SourceMustBeWall: Source type must be Wall for wall replacement.
	// NoWallSourceItems: No wall items in inventory to identify source wall.
	// TargetMustBeWallOrAir: Target type must be Wall or Air (Remove) for wall replacement.
	// SameWallSourceTarget: Source and target are the same wall [i:{0}].
	// NoWallTargetItems: No wall items found for target.
	// NoSourceWallsInSelection: No {0} walls found in selection.
	// NoWallsReplaced: No walls could be replaced.
	// ── Wiring ──────────────────────────────────────────────
	// NoWiresSelected: No wires or actuators selected.
	// NoWireInInventory: No wire in inventory.
	// NoActuatorsInInventory: No actuators in inventory.
	// WiresPlaced: Placed {0} wire segments.
	// WiresRemoved: Removed {0} wire segments.
	// NoWiringChanges: No changes made.
	// ── Safekeeping ─────────────────────────────────────────
	// NoProtectionTargets: No protection targets selected (tiles or walls).
	// NoPositionsToProtect: No positions to protect in selection.
	// NoProtectedPositions: No protected positions in selection.
	// ClearedProtection: Cleared all protection ({0} tiles, {1} walls).
	// ClearConfirmPrompt: Click again to clear {0} tile(s) and {1} wall(s).
	// ── Undo ────────────────────────────────────────────────
	// Undone: Undone: {0} ({1} tiles)
	// ── Coating ─────────────────────────────────────────────
	// CoatingNoChanges: No changes made.
	// CoatingPaintedTiles: Painted {0} tiles.
	// CoatingPaintedWalls: Painted {0} walls.
	// CoatingScrapedPaint: Scraped paint from {0} positions.
	// CoatingScrapedMoss: Removed moss from {0} tiles.
	// CoatingHarvestedMoss: Harvested moss from {0} tiles.
	// ── Fluids ──────────────────────────────────────────────
	// NoTilesInSelection: No tiles in selection area.
	// ── Delimitation Warning ──────────────────────────────
	// DelimitationFilterActive: No action executed. Delimitation Area is active and does not overlap with the selection.
	// ── Molding ─────────────────────────────────────────────
	// Shown when the player casts the Mold shape but the active ACT-ON
	// stencil slot has no committed mold yet. Gated by Preferences.WandVerbosity
	// (S15 2026-04-30 closes G-36 Q3 — verbose ⇒ chat warning, quiet ⇒
	// silent fail). Throttled in MoldShape.GetTiles to at most once per ~1s.
	// MoldEmpty: Current stencil is empty. Sculpt or load a mold with the Wand of Molding.
	// FluidsNoTiles: No tiles in selection.
	// FluidsInvalidRegion: Invalid region.
	// FluidsNoSeeds: No valid seed positions — all top tiles are solid.
	// FluidsNoBasins: No basins found — liquid cannot settle in this terrain.
	// FluidsNoPockets: No enclosed pockets found in this terrain.
	// FluidsFilled: Filled {0} tiles with {1}.
	// FluidsRainFilled: Rain Fill: {0} tiles filled ({1} columns seeded, {2} basins analyzed).
	// FluidsPocketFilled: Pocket Fill: {0} tiles filled ({1} pocket cells analyzed).
	// FluidsDrained: Drained {0} tiles.
	// FluidsBubblePlaced: Placed {0} bubble blocks.
	// FluidsBubbleRemoved: Removed {0} bubble blocks.
	// FluidsBubbleCoated: Coated selection with {0} bubble blocks.
	// FluidsMixed: Mixed {0} tiles into blocks + filled {1} tiles with {2}.
	// FluidsMixedOnly: Mixed {0} tiles into blocks.
	// ── Torches ─────────────────────────────────────────────
	// TorchesNoTorchItem: No torch found in inventory.
	// TorchesNoValidPositions: No valid torch positions in selection.
	// TorchesNonePlaced: No torches could be placed.
	// TorchesPlaced: Placed {0} torches.
	// TorchesNoneReplaced: No torches were replaced.
	// TorchesReplaced: Replaced {0} torches.
	// TorchesNoneRemoved: No torches found to remove.
	// TorchesRemoved: Removed {0} torches.
	// TorchesNoneConverted: No torches to convert (already biome-matched).
	// TorchesConverted: Converted {0} torches to biome variant.
	// ── Selection prompts (per-mode) ────────────────────────
	// SelectStartClickEnd: Selection started. Click to set end point.
	// SelectStartClickAgain: Selection started. Click again to {0}.
	// ClickToConfirm: Click again to confirm.
	// ClickToConfirmOrCancel: Click again to confirm, or right-click to cancel.
	// EndPointSet: End point set. Click again to confirm.
	// StampClickEnd: Stamp: click to set end point.
	// ── Selection prompts (per-mode) ────────────────────────
	// StampClickLock: Stamp: click to lock anchor position.
	// StampLocked: Stamp locked! Click to {0}. Right-click to reset.
	// SuppressDropsOn: Suppress Drops: ON — tile drops are suppressed.
	// SuppressDropsOff: Suppress Drops: OFF — tile drops are enabled.
	// ── Select Wand prompts ─────────────────────────────────
	// SelectClickEnd: Selection: click to set end point.
	// SelectClickConfirm: Selection: click to confirm and apply.
	// NoTilesInShape: No tiles in shape.
	// MoldingHintTooFar: No cells added — canvas is far away. Use 'Teleport to Player' in the Molding panel to bring it closer.
	// MoldingHintExpandCanvas: No cells added — shape is outside the canvas. Switch to Canvas Edit mode to expand the canvas first.
	// MoldingNoChange: Mold: no change (tiles already match the current selection).
	// ── Lore ────────────────────────────────────────────────
	// LoreCommon: The Gods of Space let you enact your thoughts into reality.
	// LoreBuilding: The Deity of Creation lets you manifest order and existence at will.
	// LoreDismantling: The Deity of Erasure lets you restore nothingness as you wish.
	// LoreReplacement: The Deity of Transmutation lets you reweave the threads of what already is.
	// LoreWiring: An advanced mechanism wrench, refined beyond the Grand Design. Where gods shape matter, engineers shape purpose.
	// LoreSafekeeping: The Deity of Timelessness lets you separate space from the powers of creation.
	// LoreCoating: The Deity of Chromas lets you dress the world in colours of your choosing.
	// LoreFluids: The Deity of Tides lets you command the flowing matter.
	// LoreTorches: The Torch God lets you spread light across the world with ease. Or awaken their wrath if you dare.
	// LoreDelimitation: The Architect of Boundaries lets you define the canvas of creation.
	// LoreMolding: The Sculptor of Forms lets you mold the blueprints of creation.
	// LoreShiftHint: "[c/888888:Hold [Shift] for lore]"
	// ── Torch Wheel Tooltips ────────────────────────────────
	// TorchWheelModeTiles: "[c/FFFF00:Mode: Tiles]"
	// TorchWheelModePlatforms: "[c/ADD8E6:Mode: Platforms]"
	// TorchWheelCycleHint: Right-click in inventory to cycle modes
	// TorchWheelKillHint: Shift + Right-click (held) to kill all projectiles
	// TorchWheelSwitchToTiles: Torch Wheel Mode: Tiles
	// TorchWheelSwitchToPlatforms: Torch Wheel Mode: Platforms
}

GameTips: {
	// VacuumItems: WSW: Don't like picking up items? Activate 'vacuum items' in the config.
	// IceBiomeReplacement: WSW: The Ice Biome got corrupted? Use the Wand of Replacement to swap them for snow. It's immune!
	// GitHubContributions: WSW: Got any bugs? Ideas? Feedback or Art? Check the github repo! Contributions are very welcome.
}

