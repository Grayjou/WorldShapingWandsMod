		// SelectiveDrain: Selective Drain
	}

	Torches: {
		// Title: Wand of Torches
		// TilingStyle: Tiling Style
		// Manhattan: Manhattan (Diamond Lattice)
		// Grid: Grid (Rectangular)
		// SpacingX: Spacing X:
		// SpacingY: Spacing Y:
		// TorchOptions: Torch Options
