}

UI: {
	Common: {
		// Shape: Shape
		// OutlineThickness: Outline Thickness:
		// Close: Close
		// Shared default-state suffixes (referenced via {$Mods.WorldShapingWandsMod.UI.Common.DefaultOn} in tooltips)
		// DefaultOn: Default: On
		// DefaultOff: Default: Off
		// Shape hover texts
		// ShapeRectFilled: Rectangle (Filled)
		// ShapeRectHollow: Rectangle (Hollow)
		// ShapeEllipseFilled: Ellipse (Filled)
		// ShapeEllipseHollow: Ellipse (Hollow)
		// ShapeDiamondFilled: Diamond (Filled)
		// ShapeDiamondHollow: Diamond (Hollow)
		// ShapeTriangleFilled: Triangle (Filled)
		// ShapeTriangleHollow: Triangle (Hollow)
		// ShapeElbow: Elbow
		// ShapeCardinal: Cardinal Line
		// ShapeStraightLine: Straight Line
		ShapeMold: Stampo (forma personalizzata)
		# (S12 2026-04-29; per GrayJou S12 prompt: "the Mold Shape Label is
		# Mold (From Wand of Molding), and I had already stated more than
		# once that it should be Mold{SelectedStencilNum} (From Wand of
		# Molding) to be more clear and encourage exploration".) {0} is the
		# 1-indexed ACT-ON stencil slot the Mold cell will stamp from.
		# Used by MoldCellWiring.cs for every wand's Mold cell hover text.
		# (S14 2026-04-29; per GrayJou S14 verbatim: *"the molding shape
		# label still doesnt have the space and the #, idk why"*) Polished
		# from `Mold{0}` to `Mold #{0}` so the slot index reads as a
		# proper ordinal ("Mold #3") instead of running together ("Mold3").
		# The S13 changelog claimed this had landed, but only the C# side
		# was touched (`HoverTextProvider` rewiring); the locale value
		# itself stayed at the pre-S13 form. Fixed here, no code change
		# needed.
		// ShapeMoldFmt: Mold #{0} (from Wand of Molding)
		// EqualDimensions: Equal Dimensions
		// ConnectDiameter: Connect Diameter
		// ConnectDiameterTooltip: Connect Diameter (hollow half-shapes only; does not clear pre-existing tiles on the open side)
		// InvertSelection: Invert Selection
		/* FlipHalfOrientation:
			'''
			Flip half orientation
			Inverts which side of the half-shape is kept relative to your drag direction.
			''' */

		PaintSprayer: {
			// $parentVal: Paint Sprayer
			# Tri-state Paint Sprayer source toggle. Click to cycle: Off -> Inventory -> Coating -> Off.
			# Inventory: consumes paint from your inventory paint sprayer (vanilla behavior).
			# Coating: applies the paint color from this wand's Coating Settings panel; no inventory consumption.
			/* Off:
				'''
				Paint Sprayer: Off
				Leaves placed tiles unpainted.
				Click to cycle (Off -> Inventory -> Coating).
				''' */
			/* Inventory:
				'''
				Paint Sprayer: Inventory
				Consumes paint from a Paint Sprayer in your inventory (vanilla behavior).
				Click to cycle.
				''' */
			/* Coating:
				'''
				Paint Sprayer: Coating Settings
				Applies the paint color configured in this wand's Coating Settings panel.
				No inventory paint consumed.
				Click to cycle.
				''' */
		}

		// PreservePaint: Preserve Paint
		// ActuationIgnore: Actuation: Ignore
		// ActuationOn: Actuation: ON
		// ActuationOff: Actuation: OFF
		/* OpenInventoryView:
			'''
			Open / Close Block Picker
			Shows the block list for this wand. Pin a block to lock placement to it.
			(The keybind for this panel is optional once you know about this button.)
			''' */
		// ChosenClickToFree: chosen — click to free
		// ChosenNotInInventory: chosen, but not in your inventory — click to free
		// ChosenItemFallback: chosen {0} not in inventory — using {1} instead
		// (S15 2026-04-28 PersistentPin) Right-click toggles pin state on IV slots.
		// Pinned items always render in the panel, even when no longer in inventory.
		// Chosen overrides pinned visually (NOT additive) per GrayJou's S15 spec.
		// PinnedRightClickToUnpin: pinned — right-click to unpin
		// PinnedNotInInventory: pinned, but not in your inventory — right-click to unpin
		// ShapeOptions: Shape Options
		// Slice: Shape Slice
	}

	// (S4 2026-04-28) Strings for the shared SubPanel primitive (UISubPanel).
	SubPanel: {
		// (S13 2026-04-28) Tooltip key names describe the *action a click would
		// take* (the inverse of the current state). UISubPanel shows LockTooltip
		// while UNLOCKED (so the action is "lock") and UnlockTooltip while
		// LOCKED (so the action is "unlock"). Body copy is state-led on line 1
		// and action-led after, to match what the player sees on hover.
		/* LockTooltip:
			'''
			Unlocked
			This SubUI will close on the next pick.
			Click to lock it open.
			''' */
		/* UnlockTooltip:
			'''
			Locked open
			This SubUI stays open after you make a selection.
			Click to unlock — it will close on the next pick.
			''' */
		// CloseTooltip: Close
	}

	# Stencil-slot row appended below the shape selector on stencil wands
	# (Wand of Molding; Wand of Delimitation TBD). Per MultipleStencilsPlan.md
	# §0.1, S6 2026-04-28. Slots are 1-indexed in UI, 0-indexed internally.
	# Stencil.PickerTitle added S7 2026-04-28 for the right-click SubUI picker
	# (MultipleStencilsPlan.md §0.2, first true SubUI primitive consumer).
	# ActOnPickerTitle added S11 2026-04-29 for the cross-wand ACT-ON picker
	# (StencilEditVsActOn.md §3, separates EDIT slot vs ACT-ON slot per
	# GrayJou's S11 worked example: "Stencil Creation Edition =/= Stencil
	# Shape Usage").
	Stencil: {
		// PickerTitle: Stencil Slot
		# (S13 2026-04-29; per GrayJou S13: *"change the locale value from
		# Mold Source Stencil to just Stencil since the source part is
		# redundant and the panel opens from an icon that says Mold from wand
		# of molding so it's already clear that it's related to molding"*.)
		// ActOnPickerTitle: Stencil
		/* Slot1:
			'''
			Stencil Slot 1
			Click to switch the active stencil to slot 1.
			Mold-shape operations use the active slot's canvas.
			''' */
		/* Slot2:
			'''
			Stencil Slot 2
			Click to switch the active stencil to slot 2.
			Mold-shape operations use the active slot's canvas.
			''' */
		/* Slot3:
			'''
			Stencil Slot 3
			Click to switch the active stencil to slot 3.
			Mold-shape operations use the active slot's canvas.
			''' */
		/* Slot4:
			'''
			Stencil Slot 4
			Click to switch the active stencil to slot 4.
			Mold-shape operations use the active slot's canvas.
			''' */
		/* Slot5:
			'''
			Stencil Slot 5
			Click to switch the active stencil to slot 5.
			Mold-shape operations use the active slot's canvas.
			''' */
	}

	Building: {
		// Title: Wand of Building
