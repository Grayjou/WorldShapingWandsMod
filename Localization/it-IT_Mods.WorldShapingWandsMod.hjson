	Selection: {
		// Title: Wand of Delimitation
		// Mode: Mode
		// ModeSelection: Selection Mode
		// ModeCanvasEdit: Canvas Edit Mode
		// Operation: Operation
		// OpAdd: Add (Union)
		// OpRemove: Remove (Subtract)
