	}

	WandOfReplacementSelect: {
		DisplayName: Varita de Reemplazo (Selección)
		Tooltip: Reemplaza Bloques en un área seleccionada
	}

	WandOfReplacementConfirm: {
		DisplayName: Varita de Reemplazo (Confirmar)
		Tooltip: Reemplaza Bloques en un área seleccionada
	}

	WandOfWiringInstant: {
		DisplayName: Varita de Cableado (Instantáneo)
		Tooltip: Coloca o quita cables y actuadores en un área seleccionada
	}

	WandOfWiringSelect: {
		DisplayName: Varita de Cableado (Selección)
		Tooltip: Coloca o quita cables y actuadores en un área seleccionada
	}

	WandOfWiringConfirm: {
		DisplayName: Varita de Cableado (Confirmar)
		Tooltip: Coloca o quita cables y actuadores en un área seleccionada
	}

	WandOfBuildingStamp: {
