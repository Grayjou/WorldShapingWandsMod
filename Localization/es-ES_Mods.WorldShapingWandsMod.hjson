		DisplayName: Varita de Desmantelamiento (Selección)
	}

	WandOfDismantlingConfirm: {
		Tooltip: ""
		DisplayName: Varita de Desmantelamiento (Confirmar)
	}

	WandOfBuildingInstant: {
		DisplayName: Varita de Construcción (Instantáneo)
		Tooltip: Coloca Bloques en un área seleccionada
	}

	WandOfBuildingSelect: {
		DisplayName: Varita de Construcción (Selección)
		Tooltip: Coloca Bloques en un área seleccionada
	}

	WandOfBuildingConfirm: {
		DisplayName: Varita de Construcción (Confirmar)
		Tooltip: Coloca Bloques en un área seleccionada
	}

	WandOfReplacementInstant: {
		DisplayName: Varita de Reemplazo (Instantáneo)
