Conditions.NonCraftable: No fabricable. Cicla modo con clic derecho en el inventario.

// ── Chat Messages ─────────────────────────────────────────
// Localization keys for all in-game chat feedback messages.
// These replace hardcoded Main.NewText() strings across the codebase.
Messages: {
	// ── Common ──────────────────────────────────────────────
	SelectionCancelled: Selección cancelada.
	// S8 2026-04-22 — keybind hint when InventoryView toggle pressed without a participating wand held.
	// S9 vocabulary pass: drop "Inventory View" user-facing wording (DesignDoc Phase A).
	InventoryViewNoParticipant: El selector de bloques solo está disponible para la Varita de Construcción, Varita de Reemplazo y Varita de Antorchas.
	SwitchedToMode: Cambiado a modo {0}
	ThicknessChanged: Grosor: {0} — {1}
	StampUnlocked: Sello retirado. Haz clic para establecer un nuevo anclaje.
	SelectionUnlocked: Selección desbloqueada. Muévete para ajustar el punto final.
	SelectionCleared: Selección borrada.
	// ── Tooltip strings ─────────────────────────────────────
	ModeInstant: Haz clic y arrastra para seleccionar área
	ModeSelect: Haz clic en inicio, luego en fin
	ModeConfirm: Haz clic en inicio, en fin, y luego haz clic para confirmar
	ModeStamp: Haz clic en inicio, en fin, haz clic para sellar la forma y posición, luego haz clic para repetir
	CycleHint: Haz clic derecho en el inventario para cambiar de modo
	PickaxeHint: Usa tu pico más fuerte para verificaciones de poder de bloque
	ObtainHint: "[c/AAAAAA:Obtén otros modos haciendo clic derecho en esta varita en tu inventario]"
	// ── Building ────────────────────────────────────────────
	NoSuitableItem: No se encontró un objeto adecuado para {0}.
	NeedHave: Necesitas {0} {1}, tienes {2}. Operación cancelada.
	NoTilesPlaced: No se pudo colocar ningún bloque.
	NoWallItemFound: No se encontró ningún objeto de pared en el inventario.
	NoWallsPlaced: No se pudo colocar ninguna pared.
	// 2026-04-23 Session 1 (Letter #10 §6) — Interrupt mode refuses to run when the
	// chosen item isn't currently in inventory. Shown in red chat instead of silently
	// substituting. Applies to both tile pins and wall pins.
	ChosenMissingUnderInterrupt: El objeto escogido no está en el inventario — el modo Interrumpir no lo sustituirá. Operación cancelada.
	// ── Dismantling ─────────────────────────────────────────
	NoTilesDestroyed: No se destruyó ningún bloque.
	// ── Void Everything ─────────────────────────────────────
	VoidRequiresCarefree: Desaparecer Todo requiere que el Modo Despreocupado esté activado.
	VoidSinglePlayerOnly: Desaparecer Todo actualmente solo está disponible en un jugador.
	NoSelectionActive: No hay selección activa. Usa una varita para seleccionar un área primero.
	NothingToVoid: No hay nada que desaparecer en el área seleccionada.
	// ── Replacement ─────────────────────────────────────────
	NoSourceItems: No hay objetos de {0} en el inventario para identificar el bloque de origen.
	SameSourceTarget: El origen y el destino son el mismo bloque [i:{0}].
	NoTargetItems: No se encontraron objetos de {0} en el inventario.
	NoSourceInSelection: No se encontró {0} en la selección.
	NeedTargetItems: Necesitas {0} [i:{1}], tienes {2}.
	NoTilesReplaced: No se pudo reemplazar ningún bloque.
	SourceMustBeWall: El tipo de origen debe ser Pared para reemplazar paredes.
	NoWallSourceItems: No hay objetos de pared en el inventario para identificar la pared de origen.
	TargetMustBeWallOrAir: El tipo de destino debe ser Pared o Aire (Eliminar) para reemplazar paredes.
	SameWallSourceTarget: El origen y el destino son la misma pared [i:{0}].
	NoWallTargetItems: No se encontraron objetos de pared para el destino.
	NoSourceWallsInSelection: No se encontraron paredes de {0} en la selección.
	NoWallsReplaced: No se pudo reemplazar ninguna pared.
	// ── Wiring ──────────────────────────────────────────────
	NoWiresSelected: No se seleccionaron cables ni actuadores.
	NoWireInInventory: No hay cable en el inventario.
	NoActuatorsInInventory: No hay actuadores en el inventario.
	WiresPlaced: Se colocaron {0} segmentos de cable.
	WiresRemoved: Se eliminaron {0} segmentos de cable.
	NoWiringChanges: No se realizaron cambios.
	// ── Safekeeping ─────────────────────────────────────────
	NoProtectionTargets: No se seleccionaron objetivos de protección (bloques o paredes).
	NoPositionsToProtect: No hay posiciones para proteger en la selección.
	NoProtectedPositions: No hay posiciones protegidas en la selección.
	ClearedProtection: Se desprotegió todo ({0} bloques, {1} paredes).
	ClearConfirmPrompt: Haz clic de nuevo para desproteger {0} bloque(s) y {1} pared(es).
	// ── Undo ────────────────────────────────────────────────
	Undone: retirado: {0} ({1} bloques)
	// ── Coating ─────────────────────────────────────────────
	CoatingNoChanges: No se realizaron cambios.
	CoatingPaintedTiles: Se pintaron {0} bloques.
	CoatingPaintedWalls: Se pintaron {0} paredes.
	CoatingScrapedPaint: Se raspó la pintura de {0} posiciones.
	CoatingScrapedMoss: Se eliminó musgo de {0} bloques.
	CoatingHarvestedMoss: Se recolectó musgo de {0} bloques.
	// ── Fluids ──────────────────────────────────────────────
	NoTilesInSelection: No hay bloques en el área de selección.
	// ── Delimitation Warning ──────────────────────────────
	DelimitationFilterActive: No se ejecutó ninguna acción. El Área de Delimitación está activa y no se superpone con la selección.
	FluidsNoTiles: No hay bloques en la selección.
	FluidsInvalidRegion: Región no válida.
	FluidsNoSeeds: No hay posiciones válidas de semilla — todos los bloques superiores son sólidos.
	FluidsNoBasins: No se encontraron cuencas — el líquido no puede asentarse en este terreno.
	FluidsNoPockets: No se encontraron cavidades cerradas en este terreno.
	FluidsFilled: Se rellenaron {0} bloques con {1}.
	FluidsRainFilled: Relleno por Lluvia: {0} bloques rellenados ({1} columnas sembradas, {2} cuencas analizadas).
	FluidsPocketFilled: Relleno de Cavidades: {0} bloques rellenados ({1} celdas de cavidad analizadas).
	FluidsDrained: Se drenaron {0} bloques.
	FluidsBubblePlaced: Se colocaron {0} bloques de burbuja.
	FluidsBubbleRemoved: Se eliminaron {0} bloques de burbuja.
	FluidsBubbleCoated: Se recubrió la selección con {0} bloques de burbuja.
	FluidsMixed: Se mezclaron {0} bloques + se rellenaron {1} bloques con {2}.
	FluidsMixedOnly: Se mezclaron {0} bloques.
	// ── Torches ─────────────────────────────────────────────
	TorchesNoTorchItem: No se encontró antorcha en el inventario.
	TorchesNoValidPositions: No hay posiciones válidas para antorchas en la selección.
	TorchesNonePlaced: No se pudieron colocar antorchas.
	TorchesPlaced: Se colocaron {0} antorchas.
	TorchesNoneReplaced: No se reemplazaron antorchas.
	TorchesReplaced: Se reemplazaron {0} antorchas.
	TorchesNoneRemoved: No se encontraron antorchas para eliminar.
	TorchesRemoved: Se eliminaron {0} antorchas.
	TorchesNoneConverted: No hay antorchas para convertir (ya coinciden con el bioma).
	TorchesConverted: Se convirtieron {0} antorchas a la variante del bioma.
	// ── Selection prompts (per-mode) ────────────────────────
	SelectStartClickEnd: Selección iniciada. Haz clic para establecer el punto final.
	SelectStartClickAgain: Selección iniciada. Haz clic de nuevo para {0}.
	ClickToConfirm: Haz clic de nuevo para confirmar.
	ClickToConfirmOrCancel: Haz clic de nuevo para confirmar, o clic derecho para cancelar.
	EndPointSet: Punto final establecido. Haz clic de nuevo para confirmar.
	StampClickEnd: Sello: haz clic para establecer el punto final.
	// ── Selection prompts (per-mode) ────────────────────────
	StampClickLock: Sello: haz clic para fijar la posición de anclaje.
	StampLocked: ¡Sello establecido! Haz clic para {0}. Clic derecho para reiniciar.
	SuppressDropsOn: Suprimir Objetos Recogibles: ACTIVADO — los objetos recogibles están suprimidos.
	SuppressDropsOff: Suprimir Objetos Recogibles: DESACTIVADO — los objetos recogibles están activados.
	// ── Select Wand prompts ─────────────────────────────────
	SelectClickEnd: Selección: haz clic para establecer el punto final.
	SelectClickConfirm: Selección: haz clic para confirmar y aplicar.
	NoTilesInShape: No hay bloques en la forma.
	MoldingHintTooFar: No se añadieron celdas — el canvas está lejos. Usa 'Teletransportar al Jugador' en el panel de Moldeo para acercarlo.
	MoldingHintExpandCanvas: No se añadieron celdas — la forma está fuera del canvas. Cambia al modo Editar Canvas para expandir el canvas primero.
	MoldingNoChange: Molde: sin cambios (los bloques ya coinciden con la selección actual).
	// ── Lore ────────────────────────────────────────────────
	LoreCommon: Los Dioses del Espacio te permiten convertir tus pensamientos en realidad.
	LoreBuilding: La Deidad de la Creación te permite manifestar orden y existencia a voluntad.
	LoreDismantling: La Deidad de la Eliminación te permite restaurar la nada a tu antojo.
	LoreReplacement: La Deidad de la Transmutación te permite retejer los hilos de lo que ya existe.
	LoreWiring: Una llave mecánica avanzada, refinada más allá del Gran Diseño. Donde los dioses moldean la materia, los ingenieros moldean el propósito.
	LoreSafekeeping: La Deidad de la Eternidad te permite separar el espacio de los poderes de la creación.
	LoreCoating: La Deidad de los Colores te permite vestir el mundo con los colores que elijas.
	LoreFluids: La Deidad de las Mareas te permite comandar la materia fluida.
	LoreTorches: El Dios de las Antorchas te permite esparcir luz por el mundo con facilidad. O despertar su ira si te atreves.
	LoreDelimitation: El Arquitecto de los Límites te permite definir el canvas de la creación.
	LoreMolding: El Escultor de Formas te permite moldear los planos de la creación.
	LoreShiftHint: "[c/888888:Mantén [Shift] para ver la historia]"
	// ── Torch Wheel Tooltips ────────────────────────────────
	TorchWheelModeTiles: "[c/FFFF00:Modo: Bloques]"
	TorchWheelModePlatforms: "[c/ADD8E6:Modo: Plataformas]"
	TorchWheelCycleHint: Clic derecho en el inventario para cambiar de modo
	TorchWheelKillHint: Shift + Clic derecho (mantenido) para eliminar todos los proyectiles
	TorchWheelSwitchToTiles: Modo Rueda de Antorchas: Bloques
	TorchWheelSwitchToPlatforms: Modo Rueda de Antorchas: Plataformas
}

GameTips: {
	VacuumItems: WSW: ¿Cansado de recoger objetos? Activa 'aspirar objetos' en la configuración.
	IceBiomeReplacement: WSW: ¿El Bioma de Hielo se corrompió? Usa la Varita de Reemplazo para cambiarlos por nieve. ¡Es inmune!
	GitHubContributions: WSW: ¿Tienes algún bug? ¿Ideas? ¿Feedback o Arte? ¡Revisa el repositorio de github! Las contribuciones son muy bienvenidas.
}

