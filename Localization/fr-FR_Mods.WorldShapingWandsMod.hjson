Configs: {
	WandConfig: {
		InfiniteResources.Header: Ressources infinies

		EnableInfiniteResource: {
			Label: Activer le mode ressources infinies
			Tooltip: Si activé, les baguettes de construction/remplacement cesseront de consommer des objets lorsque vous en avez suffisamment dans votre inventaire (voir les seuils par type ci-dessous). Mettez un seuil à 0 pour un mode toujours infini.
		}

		InfiniteTileThreshold: {
			Label: Seuil de blocs
			Tooltip:
				'''
				Si vous avez au moins ce nombre de blocs (solides, plateformes, cordes, rails) dans votre inventaire, ils ne seront pas consommés.
				0 = toujours infini pour les blocs.
				'''
		}

		InfiniteWallThreshold: {
			Label: Seuil de murs
			Tooltip:
				'''
				Si vous avez au moins ce nombre d'objets de mur dans votre inventaire, ils ne seront pas consommés.
				0 = toujours infini pour les murs.
				'''
		}

		InfiniteGrassSeedThreshold: {
			Label: Seuil de graines d'herbe
			Tooltip:
				'''
				Si vous avez au moins ce nombre de graines d'herbe dans votre inventaire, elles ne seront pas consommées.
				La valeur par défaut est 50 car les graines d'herbe sont plus rares que les blocs.
				0 = toujours infini pour les graines d'herbe.
				'''
		}

		InfiniteWireThreshold: {
			Label: Seuil de fils
			Tooltip:
				'''
				Si vous avez au moins ce nombre de fils dans votre inventaire, ils ne seront pas consommés par la Baguette de câblage.
				0 = toujours infini pour les fils.
				'''
		}

		InfiniteActuatorThreshold: {
			Label: Seuil d'actuateurs
			Tooltip:
				'''
				Si vous avez au moins ce nombre d'actuateurs dans votre inventaire, ils ne seront pas consommés par la Baguette de câblage.
				0 = toujours infini pour les actuateurs.
				'''
		}

		InfiniteTiles: {
			Label: Blocs infinis (Remplacement)
			Tooltip:
				'''
				Remplacement par type pour les blocs (solides, plateformes, cordes, rails, jardinières).
				Default : suit le bouton principal Ressources Infinies.
				ForceOn : toujours infini pour les blocs, même si le bouton principal est désactivé.
				ForceOff : jamais infini pour les blocs, même si le bouton principal est activé.
				'''
		}

		InfiniteWalls: {
			Label: Murs infinis (Remplacement)
			Tooltip:
				'''
				Remplacement par type pour les murs.
				Default : suit le bouton principal Ressources Infinies.
				ForceOn : toujours infini pour les murs, même si le bouton principal est désactivé.
				ForceOff : jamais infini pour les murs, même si le bouton principal est activé.
				'''
		}

		InfiniteGrassSeeds: {
			Label: Graines d'herbe infinies (Remplacement)
			Tooltip:
				'''
				Remplacement par type pour les graines d'herbe.
				Default : suit le bouton principal Ressources Infinies.
				ForceOn : toujours infini pour les graines, même si le bouton principal est désactivé.
				ForceOff : jamais infini pour les graines, même si le bouton principal est activé.
				'''
		}

		InfiniteWires: {
			Label: Fils infinis (Remplacement)
			Tooltip:
				'''
				Remplacement par type pour les fils.
				Default : suit le bouton principal Ressources Infinies.
				ForceOn : toujours infini pour les fils, même si le bouton principal est désactivé.
				ForceOff : jamais infini pour les fils, même si le bouton principal est activé.
				'''
		}

		InfiniteActuators: {
			Label: Actuateurs infinis (Remplacement)
			Tooltip:
				'''
				Remplacement par type pour les actuateurs.
				Default : suit le bouton principal Ressources Infinies.
				ForceOn : toujours infini pour les actuateurs, même si le bouton principal est désactivé.
				ForceOff : jamais infini pour les actuateurs, même si le bouton principal est activé.
				'''
		}

		SelectionLimits.Header: Limites des dimensions de sélection

		SmallSelectionCap: {
			Label: Limite petite forme (Coude / Cardinale)
			Tooltip: Dimension maximale (largeur ou hauteur) pour les formes Coude et Ligne cardinale.\nCes formes sont 1D, elles peuvent donc être plus longues sans problème.
		}

		BigSelectionCap: {
			Label: Limite grande forme (Rect / Ellipse / etc.)
			Tooltip: Dimension maximale (largeur ou hauteur) pour les formes de zone 2D.\nUne limite de 200 signifie que la plus grande sélection possible est de 200×200.
		}

		HollowSelectionCap: {
			Label: Limite forme creuse
			Tooltip: Dimension maximale (largeur ou hauteur) pour les formes creuses.\nLes formes creuses produisent moins de blocs que les formes pleines, elles peuvent donc être plus grandes.\nUne limite de 400 signifie que la plus grande sélection creuse est de 400×400.
		}

		ProgressiveMode.Header: Démantèlement progressif
		Sandbox.Header: Options Sandbox

		SuppressDrops: {
			Label: Supprimer les gouttes de blocs
			Tooltip: Lorsque activé, les blocs détruits par n'importe quelle baguette (démantèlement, remplacement ou échange de construction) ne laisseront pas tomber d'objets.\nUtile pour la construction créative/sandbox quand vous n'avez pas besoin de récupérer les matériaux.
		}

		BypassPickaxePower: {
			Label: Ignorer la puissance de pioche
			Tooltip: Lorsque activé, les baguettes ignorent les exigences de puissance de pioche et peuvent détruire ou remplacer n'importe quel bloc, quelle que soit la force de la pioche.\nUtile pour la construction créative/sandbox.
		}

		AllowDemonAltarDestruction: {
			Label: Autoriser la destruction des autels démoniaques
			Tooltip: Lorsque activé, la Baguette de démantèlement peut détruire les Autels démoniaques et les Autels carmin.\nPar défaut, les autels sont protégés contre la destruction massive accidentelle.\nNécessite une puissance de marteau appropriée (Pwnhammer ou mieux) sauf si Ignorer la puissance de pioche est également activé.
		}

		IgnoreLockedKeyRequirements: {
			// Label: Ignore Locked Key Requirements
			/* Tooltip:
				'''
				When enabled, locked chests can be opened by wands without needing keys.
				No keys are consumed. Useful for sandbox/builder modes.
				''' */
		}

		AutoOpenChestsOnDestruction: {
			// Label: Auto-Open Chests on Destruction
			/* Tooltip:
				'''
				When enabled, the Wand of Dismantling automatically empties and destroys
				chests in the selection. When disabled, chests are skipped entirely.
				Requires the "Destroy Containers" toggle in the wand panel to also be on.
				''' */
		}

		VacuumItems: {
			Label: Aspirer les objets lâchés
			Tooltip:
				'''
				Lorsque activé, les objets lâchés par les opérations de baguette (démantèlement,
				remplacement, échanges de construction) sont automatiquement collectés dans votre inventaire.
				Les objets en excès sont téléportés à votre position au lieu d'être dispersés.
				Sans effet lorsque Supprimer les gouttes de blocs est activé (aucun objet à collecter).
				'''
		}

		MaxOutlineThickness: {
			Label: Épaisseur maximale du contour
			Tooltip: Épaisseur maximale du contour pour les formes creuses.\nLa valeur par défaut est 10. Augmentez pour des contours plus larges, diminuez pour garder l'interface simple.\nLe bouton + dans les panneaux de baguette sera limité à cette valeur.
		}

		EnableProgressiveMode: {
			Label: Activer le mode progressif
			Tooltip: Lorsque activé, les opérations de démantèlement et de remplacement traitent les blocs par lots temporisés avec les gouttes, sons et effets appropriés.\nLorsque désactivé, les opérations sont instantanées et silencieuses (pas de gouttes de blocs).
		}

		ProgressiveBatchSize: {
			Label: Taille du lot
			Tooltip: Nombre de blocs traités par lot en mode progressif.\n400 blocs par lot est une quantité satisfaisante sans causer de latence.
		}

		ProgressiveInterval: {
			Label: Intervalle entre lots (secondes)
			Tooltip: Temps entre chaque lot en mode progressif.\n0.3 seconde donne une sensation de démolition par vagues satisfaisante.
		}

		Tooltips.Header: Options d'infobulles

		ShowLoreTooltips: {
			Label: Afficher les infobulles d'histoire
			Tooltip: Lorsque activé, maintenir la touche Maj enfoncée en survolant une baguette affiche son texte d'histoire.\nDésactivez pour masquer complètement l'histoire.
		}

		Safekeeping.Header: Préservation

		SafekeepingClearThreshold: {
			Label: Seuil de confirmation pour Tout déprotéger
			Tooltip: Lorsque le nombre total de blocs et murs protégés dépasse cette valeur, le bouton 'Tout déprotéger' nécessite un second clic pour confirmer.\nMettez à 0 pour désactiver la protection de confirmation.
		}

		Audio.Header: Audio

		EnableWandSounds: {
			Label: Activer les effets sonores des baguettes
			Tooltip: Lorsque activé, les baguettes jouent des effets sonores personnalisés lors d'une action réussie.\nDésactivez pour des opérations silencieuses.
		}

		Overlay.Header: Superposition

		OverlayRenderMode: {
			Label: Mode de rendu de la superposition
			Tooltip:
				'''
				Contrôle le rendu de la superposition de sélection pour les grandes formes.
				Auto : Affiche le cadre englobant pendant le déplacement de formes de plus de 200 blocs, puis affiche la forme complète avec transition une fois la souris stabilisée. Évite le lag lors du redimensionnement rapide. (Par défaut)
				AlwaysFullShape : Toujours rendre la forme complète immédiatement sans rebond. Peut causer du lag sur de très grandes formes mais donne un retour visuel instantané.
				AlwaysBoundingBox : Toujours afficher seulement le contour du cadre englobant, sans calculer la forme complète. Le plus léger en performance.
				'''
		}

		// DisplayName: Wand Config

		IsInfiniteForActuators: {
			// Tooltip: ""
			// Label: Is Infinite For Actuators
		}

		IsInfiniteForWires: {
			// Tooltip: ""
			// Label: Is Infinite For Wires
		}
	}

	InfiniteOverride: {
		ForceOff: {
			// Tooltip: ""
			// Label: Force Off
		}

		ForceOn: {
			// Tooltip: ""
			// Label: Force On
		}

		Default: {
			// Tooltip: ""
			// Label: Default
		}

		// Tooltip: ""
	}

	OverlayRenderMode: {
		// Tooltip: ""

		Auto: {
			// Label: Auto
			// Tooltip: ""
		}

		AlwaysFullShape: {
			// Label: Always Full Shape
			// Tooltip: ""
		}

		AlwaysBoundingBox: {
			// Label: Always Bounding Box
			// Tooltip: ""
		}
	}
}

