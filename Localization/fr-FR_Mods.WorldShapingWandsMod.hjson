Conditions.NonCraftable: Non fabriquable. Changez de mode avec un clic droit dans l'inventaire.

// ── Chat Messages ─────────────────────────────────────────
// Localization keys for all in-game chat feedback messages.
// These replace hardcoded Main.NewText() strings across the codebase.
Messages: {
	// ── Common ──────────────────────────────────────────────
	SelectionCancelled: Sélection annulée.
	SwitchedToMode: Passage en mode {0}
	ThicknessChanged: Épaisseur : {0} — {1}
	StampUnlocked: Tampon relâché. Cliquez pour définir un nouvel ancrage.
	SelectionUnlocked: Sélection déverrouillée. Déplacez-vous pour ajuster le point final.
	SelectionCleared: Sélection effacée.
	// ── Tooltip strings ─────────────────────────────────────
	ModeInstant: Cliquez et faites glisser pour sélectionner une zone
	ModeSelect: Cliquez sur le début, puis sur la fin
	ModeConfirm: Cliquez sur le début, sur la fin, puis cliquez pour confirmer
	ModeStamp: Cliquez sur le début, sur la fin, cliquez pour sceller la forme et la position, puis cliquez pour répéter
	CycleHint: Cliquez droit dans l'inventaire pour changer de mode
	PickaxeHint: Utilise votre pioche la plus puissante pour les vérifications de puissance de bloc
	ObtainHint: "[c/AAAAAA:Obtenez d'autres modes en cliquant droit sur cette baguette dans votre inventaire]"
	// ── Building ────────────────────────────────────────────
	NoSuitableItem: Aucun objet approprié trouvé pour {0}.
	NeedHave: Besoin de {0} {1}, vous en avez {2}. Opération annulée.
	NoTilesPlaced: Aucun bloc n'a pu être placé.
	NoWallItemFound: Aucun objet de mur trouvé dans l'inventaire.
	NoWallsPlaced: Aucun mur n'a pu être placé.
	// ── Dismantling ─────────────────────────────────────────
	NoTilesDestroyed: Aucun bloc n'a été détruit.
	// ── Replacement ─────────────────────────────────────────
	NoSourceItems: Aucun objet de {0} dans l'inventaire pour identifier le bloc source.
	SameSourceTarget: La source et la cible sont le même bloc [i:{0}].
	NoTargetItems: Aucun objet de {0} trouvé dans l'inventaire.
	NoSourceInSelection: Aucun {0} trouvé dans la sélection.
	NeedTargetItems: Besoin de {0} [i:{1}], vous en avez {2}.
	NoTilesReplaced: Aucun bloc n'a pu être remplacé.
	SourceMustBeWall: Le type source doit être Mur pour remplacer des murs.
	NoWallSourceItems: Aucun objet de mur dans l'inventaire pour identifier le mur source.
	TargetMustBeWallOrAir: Le type cible doit être Mur ou Air pour remplacer des murs.
	SameWallSourceTarget: La source et la cible sont le même mur [i:{0}].
	NoWallTargetItems: Aucun objet de mur trouvé pour la cible.
	NoSourceWallsInSelection: Aucun mur {0} trouvé dans la sélection.
	NoWallsReplaced: Aucun mur n'a pu être remplacé.
	// ── Wiring ──────────────────────────────────────────────
	NoWiresSelected: Aucun fil ou actionneur sélectionné.
	NoWireInInventory: Aucun fil dans l'inventaire.
	NoActuatorsInInventory: Aucun actionneur dans l'inventaire.
	WiresPlaced: "{0} segments de fil placés."
	WiresRemoved: "{0} segments de fil retirés."
	NoWiringChanges: Aucune modification effectuée.
	// ── Safekeeping ─────────────────────────────────────────
	NoProtectionTargets: Aucune cible de protection sélectionnée (blocs ou murs).
	NoPositionsToProtect: Aucune position à protéger dans la sélection.
	NoProtectedPositions: Aucune position protégée dans la sélection.
	ClearedProtection: Toute protection a été retirée ({0} blocs, {1} murs).
	ClearConfirmPrompt: Cliquez à nouveau pour déprotéger {0} bloc(s) et {1} mur(s).
	// ── Undo ────────────────────────────────────────────────
	Undone: Annulé : {0} ({1} blocs)
	// ── Coating ─────────────────────────────────────────────
	// CoatingNoChanges: No changes made.
	// CoatingPaintedTiles: Painted {0} tiles.
	// CoatingPaintedWalls: Painted {0} walls.
	// CoatingScrapedPaint: Scraped paint from {0} positions.
	// CoatingScrapedMoss: Removed moss from {0} tiles.
	// CoatingHarvestedMoss: Harvested moss from {0} tiles.
	// ── Selection prompts (per-mode) ────────────────────────
	SelectStartClickEnd: Sélection démarrée. Cliquez pour définir le point final.
	SelectStartClickAgain: Sélection démarrée. Cliquez à nouveau pour {0}.
	ClickToConfirm: Cliquez à nouveau pour confirmer.
	ClickToConfirmOrCancel: Cliquez à nouveau pour confirmer, ou clic droit pour annuler.
	EndPointSet: Point final défini. Cliquez à nouveau pour confirmer.
	// ── Stamp prompts ───────────────────────────────────────
	StampClickEnd: Tampon : cliquez pour définir le point final.
	StampClickLock: Tampon : cliquez pour fixer la position de l'ancrage.
	StampLocked: Tampon défini ! Cliquez pour {0}. Clic droit pour réinitialiser.
}
