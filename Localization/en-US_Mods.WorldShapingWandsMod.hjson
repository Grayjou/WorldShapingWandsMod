	WandOfWiringConfirm: {
		DisplayName: Wand of Wiring (Confirm)
		Tooltip: Places or removes wires and actuators in a selected area
	}

	WandOfBuildingStamp: {
		DisplayName: Wand of Building (Stamp)
		Tooltip: Define a shape once, then stamp it repeatedly
	}

	WandOfDestructionStamp: {
		DisplayName: Wand of Destruction (Stamp)
