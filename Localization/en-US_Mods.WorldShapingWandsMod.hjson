Configs: {
	WandConfig: {
		InfiniteResources.Header: Infinite Resources

		EnableInfiniteResource: {
			Label: Enable Infinite Resource Mode
			Tooltip: If enabled, building/replacement wands will stop consuming items after you have placed a certain number of blocks (see below).
		}

		InfiniteResourceAmount: {
			Label: Infinite Resource Amount
			Tooltip: If you have at least this many of a block in your inventory, it will not be consumed when placing.\n0 = always infinite (never consume).
		}

		SelectionLimits.Header: Selection Dimension Limits

		SmallSelectionCap: {
			Label: Small Shape Cap (Edge / Straight)
			Tooltip: Maximum dimension (width or height) for Edge and Straight Line shapes.\nThese shapes are 1D so they can safely be longer.
		}

		BigSelectionCap: {
			Label: Big Shape Cap (Rect / Ellipse / etc.)
			Tooltip: Maximum dimension (width or height) for 2D area shapes.\nA cap of 200 means the largest selection is 200×200.
		}

		DisplayName: Wand Config
	}
}

Items: {
	WandOfDestructionInstant: {
		DisplayName: Wand of Destruction (Instant)
		Tooltip: Destroys tiles in a selected area
	}

	WandOfDestructionSelect: {
		DisplayName: Wand of Destruction (Select)
		Tooltip: Destroys tiles in a selected area
	}

	WandOfDestructionConfirm: {
		DisplayName: Wand of Destruction (Confirm)
		Tooltip: Destroys tiles in a selected area
	}

	WandOfBuildingInstant: {
		DisplayName: Wand of Building (Instant)
		Tooltip: Places tiles in a selected area
	}

	WandOfBuildingSelect: {
		DisplayName: Wand of Building (Select)
		Tooltip: Places tiles in a selected area
	}

	WandOfBuildingConfirm: {
		DisplayName: Wand of Building (Confirm)
