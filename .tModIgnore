# ═══════════════════════════════════════════════════════════════
#  .tModIgnore — Files excluded from Workshop packaging
# ═══════════════════════════════════════════════════════════════
#  Patterns follow .gitignore syntax. Matching files are excluded
#  from the .tmod archive and Workshop uploads.
# ═══════════════════════════════════════════════════════════════

# ── Development notes & documentation ─────────────────────────
dev_notes/
UserGuides/

# ── Cloned reference projects ─────────────────────────────────
Cloned*/
ImportedSummaries/
ModReferences/

# ── Build artifacts & IDE files ───────────────────────────────
bin/
obj/
Properties/
*.sln
*.csproj.user

# ── Script & documentation files ─────────────────────────────
*.py
*.md
*.xlsx

# ── Session files & miscellaneous ─────────────────────────────
Sessions/
Session*.txt
2026-*.txt
*.old

# ── Showcase / archive / local state ──────────────────────────
ShowcaseAssets/
Archive/
PythonVenvReqs/
Scripts/
.session_state.json
.gitignore
.gitattributes
.venv/
*.bak

# ── Git files ─────────────────────────────────────────────────
.git/
.gitignore
.gitattributes